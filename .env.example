# Required
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=Cluster0
PORT=3001
JWT_SECRET=generate-a-64-char-random-hex-string-here

# SMTP — Gmail App Password (never your real account password)
# Get one at: myaccount.google.com → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
FROM_EMAIL=your-email@gmail.com

# Frontend origin for reset/verify email links and CORS
FRONTEND_URL=https://your-frontend.vercel.app
